/**
 * Prisma Schema
 * Main schema file that consolidates all models from separate domain files
 * Structure:
 * - auth.prisma: User, Profile, Role enum
 * - board.prisma: Board, Column, Task, TaskType, Priority enums
 */

// Database generator and configuration
generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  // Alpine Linux (musl libc) target — required for node:alpine Docker images
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

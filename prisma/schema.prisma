/**
 * Prisma Schema
 * Main schema file that consolidates all models from separate domain files
 * Structure:
 * - auth.prisma: User, Profile, Role enum
 * - board.prisma: Board, Column, Task, TaskType, Priority enums
 */

// Database generator and configuration
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

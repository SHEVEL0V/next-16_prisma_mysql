/**
 * Board/Kanban Schema
 * Board, column, and task models for project management
 */

/// Task type enum for categorizing tasks
enum TaskType {
  BUG
  FEATURE
  TASK
  EPIC
}

/// Priority level enum for task prioritization
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Board {
  id          String  @id @default(uuid())
  title       String
  description String?

  // Relations
  members User[]   @relation("BoardMembers")
  columns Column[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Board")
}

model Column {
  id    String @id @default(uuid())
  title String
  order Float // Float для легкого пересування (Drag & Drop)

  // Relations
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks   Task[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Column")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text // Для великого об'єму інфи
  type        TaskType  @default(TASK)
  priority    Priority  @default(MEDIUM)
  order       Float
  dueDate     DateTime?

  // Relations
  columnId  String
  column    Column @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignees User[] @relation("TaskAssignees")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Task")
}
